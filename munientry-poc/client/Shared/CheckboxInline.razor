@* Global inline checkbox component for consistent styling *@
<div class="form-check">
    <InputCheckbox Value="Value" ValueChanged="ValueChanged" class="form-check-input" id="@ResolvedId" />
    <label class="form-check-label" for="@ResolvedId">@Label</label>
</div>

@code {
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Id { get; set; } = string.Empty;

    private string ResolvedId => string.IsNullOrEmpty(Id) ? $"chk-{Label.ToLowerInvariant().Replace(" ", "-")}" : Id;
}