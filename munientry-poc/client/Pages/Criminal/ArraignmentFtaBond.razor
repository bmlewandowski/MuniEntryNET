@page "/criminal/arraignment-fta-bond"
@page "/criminal/arraignment-fta-bond/{CaseNumber}"
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components

<div class="form-page">
<div class="form-card">
<h2>Arraignment / Failure to Appear / Bond Dialogs</h2>
<!-- Legacy: arraignment_continue_dialog_ui.py, failure_to_appear_dialog_ui.py, bond_hearing_dialog_ui.py, no_plea_bond_dialog_ui.py, not_guilty_bond_dialog_ui.py -->

<EditForm Model="formModel" OnValidSubmit="HandleValidSubmit">
	<DataAnnotationsValidator />
	<ValidationSummary />
	<div class="form-group">
		<label>Defendant First Name</label>
		<InputText @bind-Value="formModel.DefendantFirstName" class="form-control" />
		<ValidationMessage For="@(() => formModel.DefendantFirstName)" />
	</div>
	<div class="form-group">
		<label>Defendant Last Name</label>
		<InputText @bind-Value="formModel.DefendantLastName" class="form-control" />
		<ValidationMessage For="@(() => formModel.DefendantLastName)" />
	</div>
	<div class="form-group">
		<label>Case Number</label>
		<InputText @bind-Value="formModel.CaseNumber" class="form-control" />
		<ValidationMessage For="@(() => formModel.CaseNumber)" />
	</div>
	<div class="form-group">
		<label>Entry Date</label>
		<InputDate @bind-Value="formModel.EntryDate" class="form-control" />
		<ValidationMessage For="@(() => formModel.EntryDate)" />
	</div>
	<div class="form-group">
		<label>Bond Type</label>
		<InputText @bind-Value="formModel.BondType" class="form-control" />
	</div>
	<div class="form-group">
		<label>Bond Amount</label>
		<InputText @bind-Value="formModel.BondAmount" class="form-control" />
	</div>
	<div class="form-group">
		<label>Defense Counsel Name</label>
		<InputText @bind-Value="formModel.DefenseCounselName" class="form-control" />
	</div>
	<div class="form-actions">
		<button type="submit" class="btn btn-success" disabled="@isSubmitting">Open Entry</button>
		<button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
		<button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
		<button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
	</div>
	@if (errorMessage != null)
	{
		<div class="alert alert-danger mt-2">@errorMessage</div>
	}
</EditForm>

</div>
</div>

@code {
	[Parameter]
	public string? CaseNumber { get; set; }
	private FormModel formModel = new();
	private bool isSubmitting = false;
	private string? errorMessage;

	private async Task HandleValidSubmit()
	{
		isSubmitting = true;
		errorMessage = null;
		// DOCX generation logic omitted for now
		await Task.Delay(500); // Simulate processing
		isSubmitting = false;
	}

	private void CloseOrCancel() => Navigation.NavigateTo("/");
	private void ClearFields() { formModel = new(); errorMessage = null; }

	protected override async Task OnInitializedAsync()
	{
		if (!string.IsNullOrWhiteSpace(CaseNumber))
		{
			// Comment out the next line to disable auto-load
			//await LoadCaseDataAsync(CaseNumber);
		}
	}

	public class FormModel
	{
		[Required(ErrorMessage = "Defendant First Name is required")]
		public string? DefendantFirstName { get; set; }

		[Required(ErrorMessage = "Defendant Last Name is required")]
		public string? DefendantLastName { get; set; }

		[Required(ErrorMessage = "Case Number is required")]
		public string? CaseNumber { get; set; }

		[Required(ErrorMessage = "Entry Date is required")]
		public DateTime? EntryDate { get; set; }

		public string? BondType { get; set; }
		public string? BondAmount { get; set; }
		public string? DefenseCounselName { get; set; }
	}
}
