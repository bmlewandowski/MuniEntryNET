@page "/criminal/plea-only-future-sentencing"
@using Munientry.Poc.Client.Shared.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="form-page">
<div class="form-card">
<h2>Plea Only - Future Sentencing Dialog</h2>

<EditForm Model="formModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="form-group">
        <label>Defendant First Name</label>
        <InputText class="form-control" @bind-Value="formModel.DefendantFirstName" />
        <ValidationMessage For="@(() => formModel.DefendantFirstName)" />
    </div>
    <div class="form-group">
        <label>Defendant Last Name</label>
        <InputText class="form-control" @bind-Value="formModel.DefendantLastName" />
        <ValidationMessage For="@(() => formModel.DefendantLastName)" />
    </div>
    <div class="form-group">
        <label>Case Number</label>
        <InputText class="form-control" @bind-Value="formModel.CaseNumber" />
        <ValidationMessage For="@(() => formModel.CaseNumber)" />
    </div>
    <div class="form-group">
        <label>Defense Counsel Name</label>
        <InputText class="form-control" @bind-Value="formModel.DefenseCounselName" />
    </div>
    <div class="form-group">
        <label>Defense Counsel Type</label>
        <InputText class="form-control" @bind-Value="formModel.DefenseCounselType" />
    </div>
    <div class="form-group">
        <InputCheckbox @bind-Value="formModel.DefenseCounselWaived" />
        <label>Defendant waived right to counsel</label>
    </div>
    <div class="form-group">
        <label>Appearance Reason</label>
        <InputText class="form-control" @bind-Value="formModel.AppearanceReason" />
    </div>
    <div class="form-group">
        <label>Plea Date</label>
        <InputDate class="form-control" @bind-Value="formModel.PleaDate" />
    </div>
    <div class="form-group">
        <label>Sentencing Date</label>
        <InputDate class="form-control" @bind-Value="formModel.SentencingDate" />
    </div>
    <div class="form-group">
        <label>Charges</label>
        <InputText class="form-control" @bind-Value="formModel.Charges" />
    </div>
    <div class="form-group">
        <label>Court Costs</label>
        <InputText class="form-control" @bind-Value="formModel.CourtCosts" />
    </div>
    <div class="form-group">
        <label>Ability to Pay</label>
        <InputText class="form-control" @bind-Value="formModel.AbilityToPay" />
    </div>
    <div class="form-group">
        <label>Balance Due Date</label>
        <InputDate class="form-control" @bind-Value="formModel.BalanceDueDate" />
    </div>
    <div class="form-group">
        <label>Pay Today</label>
        <InputText class="form-control" @bind-Value="formModel.PayToday" />
    </div>
    <div class="form-group">
        <label>Monthly Pay</label>
        <InputText class="form-control" @bind-Value="formModel.MonthlyPay" />
    </div>
    <div class="form-group">
        <InputCheckbox @bind-Value="formModel.CreditForJail" />
        <label>Credit for Jail</label>
    </div>
    <div class="form-group">
        <label>Jail Time Credit Days</label>
        <InputText class="form-control" @bind-Value="formModel.JailTimeCreditDays" />
    </div>
    <div class="form-group">
        <label>FRA in File</label>
        <InputText class="form-control" @bind-Value="formModel.FraInFile" />
    </div>
    <div class="form-group">
        <label>FRA in Court</label>
        <InputText class="form-control" @bind-Value="formModel.FraInCourt" />
    </div>
    <div class="form-group">
        <InputCheckbox @bind-Value="formModel.LicenseSuspension" />
        <label>License Suspension</label>
    </div>
    <div class="form-group">
        <InputCheckbox @bind-Value="formModel.CommunityService" />
        <label>Community Service</label>
    </div>
    <div class="form-group">
        <InputCheckbox @bind-Value="formModel.OtherConditions" />
        <label>Other Conditions</label>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-success">Open Entry</button>
        <button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
        <button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
        <button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
    </div>
</EditForm>

@if (submitResult != null)
{
    <div class="alert alert-info">@submitResult</div>
}

</div>
</div>

@code {
    private PleaOnlyFutureSentencingDto formModel = new();
    private string? submitResult;

    private async Task HandleValidSubmit()
    {
        var response = await Http.PostAsJsonAsync("/api/pleaonlyfuturesentencing", formModel);
        if (response.IsSuccessStatusCode)
        {
            submitResult = "Entry saved successfully.";
        }
        else
        {
            submitResult = "Error saving entry.";
        }
    }

    private void CloseOrCancel() => Navigation.NavigateTo("/");
    private void ClearFields() { formModel = new(); }
}
