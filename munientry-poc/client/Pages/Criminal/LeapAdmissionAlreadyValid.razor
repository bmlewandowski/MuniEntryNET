@page "/criminal/leap-admission-already-valid"
@using Munientry.Poc.Client.Shared.Models
@using Munientry.Poc.Client.Shared
@using System.ComponentModel.DataAnnotations

<div class="form-page">
    <div class="form-card">
        <h2>LEAP Admission - Already Valid Dialog</h2>
        <!-- Legacy: leap_plea_valid_dialog_ui.py -->
        <EditForm Model="formModel" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="form-group">
                <label>Defendant First Name</label>
                <InputText class="form-control" @bind-Value="formModel.DefendantFirstName" />
                <ValidationMessage For="@(() => formModel.DefendantFirstName)" />
            </div>
            <div class="form-group">
                <label>Defendant Last Name</label>
                <InputText class="form-control" @bind-Value="formModel.DefendantLastName" />
                <ValidationMessage For="@(() => formModel.DefendantLastName)" />
            </div>
            <div class="form-group">
                <label>Case Number</label>
                <InputText class="form-control" @bind-Value="formModel.CaseNumber" />
                <ValidationMessage For="@(() => formModel.CaseNumber)" />
            </div>
            <div class="form-group">
                <label>Defense Counsel Name</label>
                <InputText class="form-control" @bind-Value="formModel.DefenseCounselName" />
            </div>
            <div class="form-group">
                <CheckboxInline Value="formModel.DefenseCounselWaived" ValueChanged="@(v => formModel.DefenseCounselWaived = v)" ValueExpression="@(() => formModel.DefenseCounselWaived)" Label="Defendant waived right to counsel" />
            </div>
            <div class="form-group">
                <label>Appearance Reason</label>
                <InputText class="form-control" @bind-Value="formModel.AppearanceReason" />
            </div>
            <div class="form-group">
                <label>Admission Date</label>
                <InputDate class="form-control" @bind-Value="formModel.AdmissionDate" />
            </div>
            <div class="form-group" style="max-width:100%;">
                <label>Charges</label>
                <table class="table table-bordered table-sm">
                    <thead>
                        <tr>
                            <th>Offense</th>
                            <th>Statute</th>
                            <th>Degree</th>
                            <th>Plea</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var charge in Charges)
                        {
                            <tr>
                                <td>
                                    <InputText class="form-control form-control-sm" @bind-Value="charge.Offense" />
                                </td>
                                <td>
                                    <InputText class="form-control form-control-sm" @bind-Value="charge.Statute" />
                                </td>
                                <td>
                                    <InputSelect class="form-select form-select-sm" @bind-Value="charge.Degree">
                                        <option value="">Select Degree</option>
                                        <option value="Misdemeanor">Misdemeanor</option>
                                        <option value="Felony">Felony</option>
                                        <option value="Infraction">Infraction</option>
                                        <option value="Other">Other</option>
                                    </InputSelect>
                                </td>
                                <td>
                                    <InputSelect class="form-select form-select-sm" @bind-Value="charge.Plea">
                                        <option value="">Select Plea</option>
                                        <option value="Guilty">Guilty</option>
                                        <option value="No Contest">No Contest</option>
                                        <option value="Not Guilty">Not Guilty</option>
                                        <option value="Other">Other</option>
                                    </InputSelect>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-danger btn-sm me-1" @onclick="() => DeleteCharge(charge)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <button type="button" class="btn btn-info btn-sm me-2" @onclick="AddCharge">Add Charge</button>
                <button type="button" class="btn btn-secondary btn-sm me-2" @onclick="GuiltyAll">Guilty All</button>
            </div>
            <div class="form-group">
                <label>Court Costs</label>
                <InputText class="form-control" @bind-Value="formModel.CourtCosts" />
            </div>
            <div class="form-group">
                <label>Ability to Pay</label>
                <InputText class="form-control" @bind-Value="formModel.AbilityToPay" />
            </div>
            <div class="form-group">
                <label>Balance Due Date</label>
                <InputDate class="form-control" @bind-Value="formModel.BalanceDueDate" />
            </div>
            <div class="form-group">
                <CheckboxInline @bind-Value="formModel.CreditForJail" Label="Credit for Jail" />
            </div>
            <div class="form-group">
                <label>Monthly Pay</label>
                <InputText class="form-control" @bind-Value="formModel.MonthlyPay" />
            </div>
            <div class="form-group">
                <label>Jail Time Credit Days</label>
                <InputText class="form-control" @bind-Value="formModel.JailTimeCreditDays" />
            </div>
            <div class="form-group">
                <CheckboxInline @bind-Value="formModel.LicenseSuspension" Label="License Suspension" />
            </div>
            <div class="form-group">
                <CheckboxInline @bind-Value="formModel.CommunityService" Label="Community Service" />
            </div>
            <div class="form-group">
                <CheckboxInline @bind-Value="formModel.OtherConditions" Label="Other Conditions" />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-success me-2" disabled="@isSubmitting">Generate DOCX</button>
                <button type="button" class="btn btn-danger me-2" @onclick="CloseOrCancel">Close Dialog</button>
                <button type="button" class="btn btn-secondary me-2" @onclick="CloseOrCancel">Cancel</button>
                <button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
            </div>
            @if (errorMessage != null)
            {
                <div class="alert alert-danger mt-2">@errorMessage</div>
            }
        </EditForm>
    </div>
</div>

@code {
    private LeapAdmissionAlreadyValidDto formModel = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    // Example charge model for the grid
    private List<ChargeDto> Charges { get; set; } = new();

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        try
        {
            var apiBase = ApiHelper.GetApiBaseUrl();
            var http = new HttpClient { BaseAddress = new Uri(apiBase) };
            var response = await http.PostAsJsonAsync("leapadmissionalreadyvalid", formModel);
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsByteArrayAsync();
                var fileName = response.Content.Headers.ContentDisposition?.FileName?.Trim('"') ?? "LeapAdmissionAlreadyValid.docx";
                await JS.InvokeVoidAsync("downloadFile", fileName, "application/vnd.openxmlformats-officedocument.wordprocessingml.document", content);
                errorMessage = null;
            }
            else
            {
                errorMessage = $"Error: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void AddCharge()
    {
        Charges.Add(new ChargeDto());
    }

    private void AmendCharge(ChargeDto charge)
    {
        // Open amend dialog or inline edit logic here
    }

    private void DeleteCharge(ChargeDto charge)
    {
        Charges.Remove(charge);
    }

    private void GuiltyAll()
    {
        foreach (var charge in Charges)
        {
            charge.Plea = "Guilty";
        }
    }

    private void CloseOrCancel() => NavigationManager.NavigateTo("/");
    private void ClearFields() { formModel = new(); }

    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    [Inject] Munientry.Poc.Client.Shared.ApiHelper ApiHelper { get; set; } = default!;
    [Inject] IJSRuntime JS { get; set; } = default!;

    // Example DTO for charges
    public class ChargeDto
    {
        public string Offense { get; set; } = string.Empty;
        public string Statute { get; set; } = string.Empty;
        public string Degree { get; set; } = string.Empty;
        public string Plea { get; set; } = string.Empty;
    }
}
