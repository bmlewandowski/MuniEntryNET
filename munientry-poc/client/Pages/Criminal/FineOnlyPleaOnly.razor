@page "/criminal/fine-only-plea-only"
@using Munientry.Poc.Client.Shared.Models
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager Navigation

<div class="form-page">
<div class="form-card">
<h2>Fine Only Dialog</h2>
<!-- Legacy: fine_only_plea_dialog_ui.py, plea_only_dialog_ui.py -->

<EditForm Model="model" OnValidSubmit="HandleSubmit">
	<DataAnnotationsValidator />
	<ValidationSummary />
	<div>
		<label>Case Number</label><br />
		<InputText @bind-Value="model.CaseNumber" />
	</div>
	<div>
		<label>Defendant Name</label><br />
		<InputText @bind-Value="model.DefendantName" />
	</div>
	<div>
		<label>Charge</label><br />
		<InputText @bind-Value="model.Charge" />
	</div>
	<div>
		<label>Fine Amount</label><br />
		<InputNumber @bind-Value="model.FineAmount" TValue="decimal?" />
	</div>
	<div class="form-actions">
		<button type="submit" class="btn btn-success">Open Entry</button>
		<button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
		<button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
		<button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
		<span style="margin-left:1rem">@_message</span>
	</div>
</EditForm>

</div>
</div>

@code {
	private FineOnlyDto model = new();
	private string _message = "";

	private async Task HandleSubmit()
	{
		try
		{
			var apiBase = Navigation.BaseUri.Replace(":3000", ":5000");
			var client = new System.Net.Http.HttpClient { BaseAddress = new Uri(apiBase) };
			var res = await client.PostAsJsonAsync("api/fineonly", model);
			if (res.IsSuccessStatusCode) _message = "Submitted!";
			else _message = "Error: " + res.StatusCode;
		}
		catch (Exception ex)
		{
			_message = ex.Message;
		}
	}

	private void CloseOrCancel() => Navigation.NavigateTo("/");
	private void ClearFields() { model = new(); _message = ""; }
}
