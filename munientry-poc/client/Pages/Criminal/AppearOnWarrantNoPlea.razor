@page "/criminal/appear-on-warrant-no-plea"
@page "/criminal/appear-on-warrant-no-plea/{CaseNumber}"
@inherits FormPageBase<AppearOnWarrantNoPleaDto>

<div class="form-page">
<div class="form-card">
<h2>Appear on Warrant (No Plea) Dialog</h2>

<EditForm Model="formModel" OnValidSubmit="HandleValidSubmit">
<DataAnnotationsValidator />
@if (IsLoadingCase)
{
<div class="alert alert-info">Loading case data...</div>
}
	<ValidationSummary />
	<div class="form-group">
		<label>Defendant First Name</label>
		<InputText class="form-control" @bind-Value="formModel.DefendantFirstName" />
		<ValidationMessage For="@(() => formModel.DefendantFirstName)" />
	</div>
	<div class="form-group">
		<label>Defendant Last Name</label>
		<InputText class="form-control" @bind-Value="formModel.DefendantLastName" />
		<ValidationMessage For="@(() => formModel.DefendantLastName)" />
	</div>
	<div class="form-group">
		<label>Case Number</label>
		<InputText class="form-control" @bind-Value="formModel.CaseNumber" />
		<ValidationMessage For="@(() => formModel.CaseNumber)" />
	</div>
	<div class="form-group">
		<label>Bond Type</label>
		<InputText class="form-control" @bind-Value="formModel.BondType" />
	</div>
	<div class="form-group">
		<label>Bond Amount</label>
		<InputText class="form-control" @bind-Value="formModel.BondAmount" />
	</div>
	<div class="form-group">
		<label>No Contact Name</label>
		<InputText class="form-control" @bind-Value="formModel.NoContactName" />
	</div>
	<div class="form-group">
		<label>Custodial Supervision Supervisor</label>
		<InputText class="form-control" @bind-Value="formModel.CustodialSupervisionSupervisor" />
	</div>
	<div class="form-group">
		<label>Admin License Suspension Objection</label>
		<InputText class="form-control" @bind-Value="formModel.AdminLicenseSuspensionObjection" />
	</div>
	<div class="form-group">
		<label>Admin License Suspension Disposition</label>
		<InputText class="form-control" @bind-Value="formModel.AdminLicenseSuspensionDisposition" />
	</div>
	<div class="form-group">
		<label>Admin License Suspension Explanation</label>
		<InputText class="form-control" @bind-Value="formModel.AdminLicenseSuspensionExplanation" />
	</div>
	<div class="form-group">
		<label>Vehicle Make/Model</label>
		<InputText class="form-control" @bind-Value="formModel.VehicleMakeModel" />
	</div>
	<div class="form-group">
		<label>Vehicle License Plate</label>
		<InputText class="form-control" @bind-Value="formModel.VehicleLicensePlate" />
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="formModel.TowToResidence" />
		<label>Tow to Residence</label>
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="formModel.MotionToReturnVehicle" />
		<label>Motion to Return Vehicle</label>
	</div>
	<div class="form-group">
		<label>State Opposes</label>
		<InputText class="form-control" @bind-Value="formModel.StateOpposes" />
	</div>
	<div class="form-group">
		<label>Disposition Motion to Return</label>
		<InputText class="form-control" @bind-Value="formModel.DispositionMotionToReturn" />
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="formModel.VacateResidence" />
		<label>Vacate Residence</label>
	</div>
	<div class="form-group">
		<label>Residence Address</label>
		<InputText class="form-control" @bind-Value="formModel.ResidenceAddress" />
	</div>
	<div class="form-group">
		<label>Exclusive Possession To</label>
		<InputText class="form-control" @bind-Value="formModel.ExclusivePossessionTo" />
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="formModel.SurrenderWeapons" />
		<label>Surrender Weapons</label>
	</div>
	<div class="form-group">
		<label>Surrender Weapons Date</label>
		<InputText class="form-control" @bind-Value="formModel.SurrenderWeaponsDate" />
	</div>
	<div class="form-actions">
		<button type="submit" class="btn btn-success" disabled="@(IsSubmitting || IsLoadingCase)">Open Entry</button>
		<button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
		<button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
		<button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
	</div>
</EditForm>

@if (SubmitResult != null)
{
	<div class="alert alert-info">@SubmitResult</div>
}
@if (ErrorMessage != null)
{
	<div class="alert alert-danger">@ErrorMessage</div>
}
</div>
</div>
@code {
	private AppearOnWarrantNoPleaDto formModel => Model;

	protected override string ApiEndpoint => "api/appearonwarrantnoplea";

	protected override Task PopulateFromCaseAsync(List<CaseSearchResultDto> results)
	{
		var first = results[0];
		Model.CaseNumber = CaseNumber;
		Model.DefendantFirstName = first.DefFirstName;
		Model.DefendantLastName = first.DefLastName;
		return Task.CompletedTask;
	}
}
