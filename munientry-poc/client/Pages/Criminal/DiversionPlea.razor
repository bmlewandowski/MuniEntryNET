@page "/criminal/diversion-plea"
@using Munientry.Poc.Client.Dtos
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="form-page">
<div class="form-card">
<h2>Diversion Dialog</h2>

<EditForm Model="diversionPlea" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="form-group">
        <label>Defendant First Name</label>
        <InputText @bind-Value="diversionPlea.DefendantFirstName" class="form-control" />
    </div>
    <div class="form-group">
        <label>Defendant Last Name</label>
        <InputText @bind-Value="diversionPlea.DefendantLastName" class="form-control" />
    </div>
    <div class="form-group">
        <label>Case Number</label>
        <InputText @bind-Value="diversionPlea.CaseNumber" class="form-control" />
    </div>
    <div class="form-group">
        <label>Date</label>
        <InputDate @bind-Value="diversionPlea.Date" class="form-control" />
    </div>
    <div class="form-group">
        <label>Defense Counsel Name</label>
        <InputText @bind-Value="diversionPlea.DefenseCounselName" class="form-control" />
    </div>
    <div class="form-group">
        <label>Defense Counsel Type</label>
        <InputText @bind-Value="diversionPlea.DefenseCounselType" class="form-control" />
    </div>
    <div class="form-group">
        <label>Defense Counsel Waived</label>
        <InputCheckbox @bind-Value="diversionPlea.DefenseCounselWaived" />
    </div>
    <div class="form-group">
        <label>Appearance Reason</label>
        <InputText @bind-Value="diversionPlea.AppearanceReason" class="form-control" />
    </div>
    <div class="form-group">
        <label>Charges</label>
        <InputText @bind-Value="diversionPlea.Charges" class="form-control" />
    </div>
    <div class="form-group">
        <label>Diversion Type</label>
        <InputText @bind-Value="diversionPlea.DiversionType" class="form-control" />
    </div>
    <div class="form-group">
        <label>Diversion Completion Date</label>
        <InputDate @bind-Value="diversionPlea.DiversionCompletionDate" class="form-control" />
    </div>
    <div class="form-group">
        <label>Diversion Fine Pay Date</label>
        <InputDate @bind-Value="diversionPlea.DiversionFinePayDate" class="form-control" />
    </div>
    <div class="form-group">
        <label>Probation</label>
        <InputCheckbox @bind-Value="diversionPlea.Probation" />
    </div>
    <div class="form-group">
        <label>Pay Restitution</label>
        <InputCheckbox @bind-Value="diversionPlea.PayRestitution" />
    </div>
    <div class="form-group">
        <label>Pay Restitution To</label>
        <InputText @bind-Value="diversionPlea.PayRestitutionTo" class="form-control" />
    </div>
    <div class="form-group">
        <label>Pay Restitution Amount</label>
        <InputNumber @bind-Value="diversionPlea.PayRestitutionAmount" class="form-control" />
    </div>
    <div class="form-group">
        <label>Other Conditions</label>
        <InputCheckbox @bind-Value="diversionPlea.OtherConditions" />
    </div>
    <div class="form-group">
        <label>Other Conditions Text</label>
        <InputText @bind-Value="diversionPlea.OtherConditionsText" class="form-control" />
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-success" disabled="@isSubmitting">Generate DOCX</button>
        <button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
        <button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
        <button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
    </div>
</EditForm>

@if (submitResult != null)
{
    <div class="alert alert-success">@submitResult</div>
}

</div>
</div>

@code {
    DiversionPleaDto diversionPlea = new();
    string submitResult;
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        try
        {
            var apiBase = ApiHelper.GetApiBaseUrl();
            var http = new HttpClient { BaseAddress = new Uri(apiBase) };
            var response = await http.PostAsJsonAsync("diversionplea", diversionPlea);
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsByteArrayAsync();
                var fileName = response.Content.Headers.ContentDisposition?.FileName?.Trim('"') ?? "DiversionPlea.docx";
                await JS.InvokeVoidAsync("downloadFile", fileName, "application/vnd.openxmlformats-officedocument.wordprocessingml.document", content);
                submitResult = "Diversion Plea DOCX generated.";
            }
            else
            {
                errorMessage = $"Error: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void CloseOrCancel() => Navigation.NavigateTo("/");
    private void ClearFields() { diversionPlea = new(); }

    [Inject] IJSRuntime JS { get; set; } = default!;
    [Inject] Munientry.Poc.Client.Shared.ApiHelper ApiHelper { get; set; } = default!;
}
