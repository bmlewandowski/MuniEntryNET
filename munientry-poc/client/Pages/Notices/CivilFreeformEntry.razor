@page "/notices/civil-freeform-entry"
@using Munientry.Poc.Client.Shared.Models

<div class="form-page">
<div class="form-card">
<h2>Civil Freeform Entry Dialog</h2>

<EditForm Model="formModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="form-group">
        <label>Entry Date</label>
        <InputDate class="form-control" @bind-Value="formModel.EntryDate" />
    </div>
    <div class="form-group">
        <label>Plaintiff</label>
        <InputText class="form-control" @bind-Value="formModel.Plaintiff" />
    </div>
    <div class="form-group">
        <label>Defendant</label>
        <InputText class="form-control" @bind-Value="formModel.Defendant" />
    </div>
    <div class="form-group">
        <label>Case Number</label>
        <InputText class="form-control" @bind-Value="formModel.CaseNumber" />
    </div>
    <div class="form-group">
        <label>Appearance Reason</label>
        <InputText class="form-control" @bind-Value="formModel.AppearanceReason" />
    </div>
    <div class="form-group">
        <label>Entry Content</label>
        <InputTextArea class="form-control" @bind-Value="formModel.EntryContent" />
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-success" disabled="@isSubmitting">Generate DOCX</button>
    </div>
</EditForm>

</div>
</div>

@code {
    private CivilFreeformEntryDto formModel = new();
    private bool isSubmitting = false;
    private string? submitResult;
    private string? errorMessage;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        try
        {
            var apiBase = ApiHelper.GetApiBaseUrl();
            var http = new HttpClient { BaseAddress = new Uri(apiBase) };
            var response = await http.PostAsJsonAsync("civilfreeformentry", formModel);
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsByteArrayAsync();
                var fileName = response.Content.Headers.ContentDisposition?.FileName?.Trim('"') ?? "CivilFreeformEntry.docx";
                await JS.InvokeVoidAsync("downloadFile", fileName, "application/vnd.openxmlformats-officedocument.wordprocessingml.document", content);
                submitResult = "Civil Freeform Entry DOCX generated.";
            }
            else
            {
                errorMessage = $"Error: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    [Inject] IJSRuntime JS { get; set; } = default!;
    [Inject] Munientry.Poc.Client.Shared.ApiHelper ApiHelper { get; set; } = default!;
}
