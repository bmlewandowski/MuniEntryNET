@page "/probation/violation-bond"
@using Munientry.Poc.Client.Shared.Models

<h2>Preliminary Probation Violation and Bond Dialog</h2>

<EditForm Model="formModel" OnValidSubmit="HandleValidSubmit">
	<DataAnnotationsValidator />
	<ValidationSummary />
	<div>
		<label>Defendant First Name</label>
		<InputText @bind-Value="formModel.DefendantFirstName" />
	</div>
	<div>
		<label>Defendant Last Name</label>
		<InputText @bind-Value="formModel.DefendantLastName" />
	</div>
	<div>
		<label>Case Number</label>
		<InputText @bind-Value="formModel.CaseNumber" />
	</div>
	<div>
		<label>Appearance Reason</label>
		<InputText @bind-Value="formModel.AppearanceReason" />
	</div>
	<div>
		<label>Defense Counsel Name</label>
		<InputText @bind-Value="formModel.DefenseCounselName" />
	</div>
	<div>
		<label>Defense Counsel Type</label>
		<InputSelect @bind-Value="formModel.DefenseCounselType">
			<option value="Public Defender">Public Defender</option>
			<option value="Private Counsel">Private Counsel</option>
		</InputSelect>
	</div>
	<div>
		<label>Defense Counsel Waived</label>
		<InputCheckbox @bind-Value="formModel.DefenseCounselWaived" />
	</div>
	<div>
		<label>Probable Cause Finding</label>
		<InputSelect @bind-Value="formModel.ProbableCauseFinding">
			<option value="Stipulates">Defendant stipulates probable cause exists</option>
			<option value="Court Finds">Court finds probable cause</option>
			<option value="No Probable Cause">No probable cause</option>
		</InputSelect>
	</div>
	<div>
		<label>Bond Type</label>
		<InputSelect @bind-Value="formModel.BondType">
			<option value="No Bond">No Bond</option>
			<option value="Recognizance (OR) Bond">Recognizance (OR) Bond</option>
			<option value="10% Deposit, Cash or Surety Bond">10% Deposit, Cash or Surety Bond</option>
			<option value="Cash or Surety Bond">Cash or Surety Bond</option>
		</InputSelect>
	</div>
	<div>
		<label>Bond Amount</label>
		<InputSelect @bind-Value="formModel.BondAmount">
			<option value="None">None</option>
			<option value="$1,000">$1,000</option>
			<option value="$1,500">$1,500</option>
			<option value="$2,000">$2,000</option>
			<option value="$2,500">$2,500</option>
			<option value="$3,000">$3,000</option>
			<option value="$3,500">$3,500</option>
			<option value="$5,000">$5,000</option>
			<option value="$7,500">$7,500</option>
			<option value="$10,000">$10,000</option>
		</InputSelect>
	</div>
	<div>
		<label>No alcohol/drugs of abuse</label>
		<InputCheckbox @bind-Value="formModel.NoAlcoholDrugs" />
	</div>
	<div>
		<label>Monitoring (GPS/Scram/Smart Start)</label>
		<InputCheckbox @bind-Value="formModel.Monitoring" />
	</div>
	<div>
		<label>Monitoring Type</label>
		<InputSelect @bind-Value="formModel.MonitoringType">
			<option value="SCRAM Only">SCRAM Only</option>
			<option value="GPS Only">GPS Only</option>
			<option value="Smart Start Only">Smart Start Only</option>
		</InputSelect>
	</div>
	<div>
		<label>Comply with Terms of Protection Order</label>
		<InputCheckbox @bind-Value="formModel.ComplyProtectionOrder" />
	</div>
	<div>
		<label>Other Conditions</label>
		<InputCheckbox @bind-Value="formModel.OtherConditions" />
	</div>
	<button type="submit">Submit</button>
</EditForm>

@code {
	private ProbationViolationBondDto formModel = new();

	private async Task HandleValidSubmit()
	{
		// TODO: Call API to save form data
	}
}
