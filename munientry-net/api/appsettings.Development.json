{
  // Development overrides — loaded automatically when ASPNETCORE_ENVIRONMENT=Development.
  // Values here are merged on top of appsettings.json; only overrides are listed.

  "DailyList": {
    // true  → forward @ReportDate to the 6 daily-list SPs so any date can be queried via the URL.
    //         Requires the DBA to have applied the SP update (see docs/StoredProcedureIntegration.md).
    // false → omit the parameter; SP uses GETDATE() internally (same as production behavior).
    "PassDateParameter": true
  }
}
