{
  "ConnectionStrings": {
    // Local dev (dotnet run): Windows Authentication — the process runs as the logged-in domain account.
    // Docker: Windows Auth is not supported in Linux containers. Set the
    //   AUTHORITY_COURT_CONNSTR environment variable (e.g. in a .env file) to a SQL login connection
    //   string and docker-compose will override this value at runtime.
    //   Example SQL login override:
    //     Server=host.docker.internal;Database=AuthorityCourt;User Id=munientry_app;Password=CHANGE_ME;TrustServerCertificate=True;
    "AuthorityCourt": "Server=localhost;Database=AuthorityCourt;Integrated Security=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      // Audit records from AuditMiddleware — kept at Information so every
      // request generates a record regardless of the Default level above.
      "Munientry.Api.Middleware": "Information"
    }
  },
  "AllowedHosts": "*",
  // DailyList:PassDateParameter controls whether @ReportDate is forwarded to the 6 daily-list SPs.
  // false (default) = production mode: SPs use GETDATE() internally; no parameter is passed.
  // true            = dev/test mode: the date from the URL is forwarded to @ReportDate.
  //                   REQUIRES the SPs to have been updated to accept @ReportDate DATE = NULL.
  //                   See docs/StoredProcedureIntegration.md — "Daily Case List SP Update" section.
  "DailyList": {
    "PassDateParameter": false
  },
  // Scheduling:JudgeTemplates maps judicial officer last names to DOCX template filenames.
  // Add or rename entries here when the bench changes — no code change is required.
  // Scheduling:DefaultTemplate is used when the judicial officer name is not in JudgeTemplates.
  "Scheduling": {
    "DefaultTemplate": "Scheduling_Entry_Template_Rohrer.docx",
    "JudgeTemplates": {
      "Fowler":   "Scheduling_Entry_Template_Fowler.docx",
      "Hemmeter": "Scheduling_Entry_Template_Hemmeter.docx",
      "Rohrer":   "Scheduling_Entry_Template_Rohrer.docx"
    }
  },
  // ENTRA ID - Step 3: Fill in TenantId and ClientId before enabling auth.
  // Steps to get these values:
  //   - TenantId:  Azure Portal > Entra ID > Overview > Tenant ID
  //   - ClientId:  create a dedicated App Registration for this API (separate from the client's registration)
  //                Expose the API: add a scope (e.g. "access_as_user"); the Audience is the Application ID URI (api://<ClientId>)
  //                Grant the client's App Registration permission to this API scope
  // "AzureAd": {
  //   "Instance": "https://login.microsoftonline.com/",
  //   "TenantId": "<your-tenant-id>",
  //   "ClientId": "<your-api-client-id>",
  //   "Audience": "api://<your-api-client-id>"
  // }
}
