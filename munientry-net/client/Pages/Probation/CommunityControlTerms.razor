@page "/probation/community-control-terms/{CaseNumber}"
@page "/probation/community-control-terms"
@inherits FormPageBase<CommunityControlTermsDto>

<PageTitle>Community Control Terms</PageTitle>

<div class="form-page">
<div class="form-card">
<h3>Community Control Terms</h3>

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
    <FluentValidationValidator />
    @if (IsLoadingCase)
    {
        <div class="alert alert-info">Loading case data...</div>
    }
    @if (IsLoadingCase)
    {
        <div class="alert alert-info">Loading case data...</div>
    }
    @if (IsLoadingCase)
    {
        <div class="alert alert-info">Loading case data...</div>
    }
    @if (IsLoadingCase)
    {
        <div class="alert alert-info">Loading case data...</div>
    }
    <ValidationSummary />
    <fieldset>
        <legend>Case/Defendant Information</legend>
        <div class="form-row">
            <label>Defendant First Name:</label>
            <InputText @bind-Value="Model.DefendantFirstName" class="form-control" />
        </div>
        <div class="form-row">
            <label>Defendant Last Name:</label>
            <InputText @bind-Value="Model.DefendantLastName" class="form-control" />
        </div>
        <div class="form-row">
            <label>Case Number:</label>
            <InputText @bind-Value="Model.CaseNumber" class="form-control" />
        </div>
        <div class="form-row">
            <label>Entry Date:</label>
            <InputDate @bind-Value="Model.EntryDate" class="form-control" />
        </div>
    </fieldset>
    <fieldset>
        <legend>Community Control Terms</legend>
        <div class="form-row">
            <label>Term of Control:</label>
            <InputSelect @bind-Value="Model.TermOfControl" class="form-control">
                <option>1 year</option>
                <option>6 months</option>
                <option>18 months</option>
                <option>2 years</option>
                <option>3 years</option>
                <option>4 years</option>
                <option>5 years</option>
            </InputSelect>
        </div>
        <div class="form-row">
            <label>Report Frequency:</label>
            <InputSelect @bind-Value="Model.ReportFrequency" class="form-control">
                <option>daily (Monday through Friday)</option>
                <option>every Monday</option>
                <option>once a week (as ordered)</option>
            </InputSelect>
        </div>
        <div class="form-row">
            <label>Report to Jail:</label>
            <InputCheckbox @bind-Value="Model.ReportToJail" />
        </div>
        <div class="form-row">
            <label>Jail Report Date:</label>
            <InputDate @bind-Value="Model.JailReportDate" class="form-control" />
        </div>
        <div class="form-row">
            <label>Jail Report Time:</label>
            <InputText @bind-Value="Model.JailReportTime" class="form-control" />
        </div>
        <div class="form-row">
            <label>Jail Days to Serve:</label>
            <InputText @bind-Value="Model.JailDaysToServe" class="form-control" />
        </div>
    </fieldset>
    <fieldset>
        <legend>Conditions</legend>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.InterlockVehicles" /> Only operate vehicles with certified ignition interlock</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.NoAlcoholOrdered" /> No Alcohol Conditions</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.GpsExclusion" /> Comply with court ordered GPS Exclusion Zone</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.ScramOrdered" /> Submit to continuous alcohol monitoring (SCRAM) for:</label>
            <InputSelect @bind-Value="Model.ScramDays" class="form-control">
                <option>15 days</option>
                <option>30 days</option>
                <option>45 days</option>
                <option>60 days</option>
                <option>75 days</option>
                <option>90 days</option>
                <option>180 days</option>
            </InputSelect>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.NoContact" /> No Contact with:</label>
            <InputText @bind-Value="Model.NoContactWith" class="form-control" placeholder="No Contact Person(s) Name(s)" />
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.Antitheft" /> Complete Anti-theft/Shoplifting Program</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.AlcoholTreatment" /> Comply with Alcohol/Drug Dependency Counseling and Treatment</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.DomesticViolenceProgram" /> Complete Domestic Violence Offender Program</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.AngerManagement" /> Complete Anger Management Class</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.MentalHealthTreatment" /> Comply with Mental Health Counseling and Treatment</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.DriverInterventionProgram" /> Complete Driver Intervention Program</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.CommunityService" /> Community Service required</label>
            <InputSelect @bind-Value="Model.CommunityServiceHours" class="form-control">
                <option>25 hours</option>
                <option>50 hours</option>
                <option>100 hours</option>
                <option>200 hours</option>
                <option>500 hours</option>
            </InputSelect>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.PayRestitution" /> Pay Restitution as ordered by the Court</label>
        </div>
        <div class="form-row">
            <label><InputCheckbox @bind-Value="Model.SpecializedDocket" /> Agree to comply with terms of specialized docket:</label>
            <InputSelect @bind-Value="Model.SpecializedDocketType" class="form-control">
                <option>OVI Docket</option>
                <option>Mental Health Docket</option>
                <option>Mission (Veteran's) Court</option>
            </InputSelect>
        </div>
    </fieldset>
    <div class="form-row mt-3">
        <button type="submit" class="btn btn-success" disabled="@(IsSubmitting || IsLoadingCase)">Open Entry</button>
        <button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
        <button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
        <button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
    </div>
</EditForm>

</div>
</div>

@code {

    // ApiEndpoint empty — submit not yet implemented
    protected override string ApiEndpoint => "communitycontrolterms";

    protected override Task PopulateFromCaseAsync(List<CaseSearchResultDto> results)
    {
        var first = results[0];
        Model.CaseNumber = CaseNumber;
        Model.DefendantFirstName = first.DefFirstName;
        Model.DefendantLastName = first.DefLastName;
        return Task.CompletedTask;
    }
}
