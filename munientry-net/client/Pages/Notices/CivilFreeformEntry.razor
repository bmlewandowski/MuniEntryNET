@page "/notices/civil-freeform-entry"
@page "/notices/civil-freeform-entry/{CaseNumber}"
@inherits FormPageBase<CivilFreeformEntryDto>

<div class="form-page">
<div class="form-card">
<h2>Civil Freeform Entry Dialog</h2>

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
    <FluentValidationValidator />
    <ValidationSummary />
    <div class="form-group">
        <label>Entry Date</label>
        <InputDate class="form-control" @bind-Value="Model.EntryDate" />
    </div>
    <div class="form-group">
        <label>Plaintiff</label>
        <InputText class="form-control" @bind-Value="Model.Plaintiff" />
    </div>
    <div class="form-group">
        <label>Defendant</label>
        <InputText class="form-control" @bind-Value="Model.Defendant" />
    </div>
    <div class="form-group">
        <label>Case Number</label>
        <InputText class="form-control" @bind-Value="Model.CaseNumber" />
    </div>
    <div class="form-group">
        <label>Appearance Reason</label>
        <InputText class="form-control" @bind-Value="Model.AppearanceReason" />
    </div>
    <div class="form-group">
        <label>Entry Content</label>
        <InputTextArea class="form-control" @bind-Value="Model.EntryContent" />
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-success" disabled="@IsSubmitting">Generate DOCX</button>
    </div>
</EditForm>

</div>
</div>

@code {
    protected override string ApiEndpoint => "civilfreeformentry";
}
