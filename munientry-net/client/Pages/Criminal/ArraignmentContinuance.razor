@page "/Criminal/ArraignmentContinuance"
@using munientry_poc.client.Shared.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Arraignment Continuance</PageTitle>

<div class="form-page">
<div class="form-card">
<h3>Arraignment Continuance</h3>

<EditForm Model="continuance" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="form-section">
        <h4>Case Information</h4>
        <div class="form-group">
            <label>Defendant First Name</label>
            <InputText @bind-Value="continuance.DefendantFirstName" class="form-control" />
        </div>
        <div class="form-group">
            <label>Defendant Last Name</label>
            <InputText @bind-Value="continuance.DefendantLastName" class="form-control" />
        </div>
        <div class="form-group">
            <label>Case Number</label>
            <InputText @bind-Value="continuance.CaseNumber" class="form-control" />
        </div>
        <div class="form-group">
            <label>Date (Plea/Trial)</label>
            <InputDate @bind-Value="continuance.PleaTrialDate" class="form-control" />
        </div>
        <div class="form-group">
            <label>Defense Counsel Name</label>
            <InputText @bind-Value="continuance.DefenseCounselName" class="form-control" />
        </div>
        <div class="form-group">
            <label>Defense Counsel Type</label>
            <InputSelect @bind-Value="continuance.DefenseCounselType" class="form-control">
                <option value="">Select</option>
                <option value="Public Defender">Public Defender</option>
                <option value="Private Counsel">Private Counsel</option>
            </InputSelect>
        </div>
        <div class="form-group">
            <InputCheckbox @bind-Value="continuance.CounselWaived" /> Defendant appeared without counsel
        </div>
        <div class="form-group">
            <label>Appearance Reason</label>
            <InputSelect @bind-Value="continuance.AppearanceReason" class="form-control">
                <option value="">Select</option>
                <option value="arraignment">arraignment</option>
                <option value="final community control violation hearing">final community control violation hearing</option>
                <option value="preliminary community control violation hearing">preliminary community control violation hearing</option>
                <option value="final pre-trial">final pre-trial</option>
                <option value="LEAP sentencing">LEAP sentencing</option>
                <option value="jury trial">jury trial</option>
                <option value="trial to court">trial to court</option>
                <option value="motion hearing">motion hearing</option>
                <option value="warrant for failure to appear">warrant for failure to appear</option>
            </InputSelect>
        </div>
    </div>
    <div class="form-section">
        <h4>Continuance Information</h4>
        <div class="form-group">
            <label>Current Arraignment Date</label>
            <InputDate @bind-Value="continuance.CurrentArraignmentDate" class="form-control" />
        </div>
        <div class="form-group">
            <label>New Arraignment Date</label>
            <InputDate @bind-Value="continuance.NewArraignmentDate" class="form-control" />
        </div>
        <div class="form-group">
            <label>Continuance Length</label>
            <InputSelect @bind-Value="continuance.ContinuanceLength" class="form-control">
                <option value="">Select</option>
                <option value="2 Weeks">2 Weeks</option>
                <option value="1 Week">1 Week</option>
            </InputSelect>
        </div>
        <div class="form-group">
            <label>Continuance Reason</label>
            <InputSelect @bind-Value="continuance.ContinuanceReason" class="form-control">
                <option value="">Select</option>
                <option value="to arrange for an interpreter for defendant">to arrange for an interpreter for defendant</option>
                <option value="general continuance - granted">general continuance - granted</option>
                <option value="general continuance - denied untimely">general continuance - denied untimely</option>
                <option value="to allow defendant to obtain counsel">to allow defendant to obtain counsel</option>
            </InputSelect>
        </div>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-success">Open Entry</button>
        <button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
        <button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
        <button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
    </div>
</EditForm>

</div>
</div>

@code {
    private ArraignmentContinuanceDto continuance = new();

    private async Task HandleValidSubmit()
    {
        var response = await Http.PostAsJsonAsync("/api/arraignmentcontinuance", continuance);
        if (response.IsSuccessStatusCode)
        {
            var content = await response.Content.ReadAsByteArrayAsync();
            var fileName = response.Content.Headers.ContentDisposition?.FileName?.Trim('"') ?? "ArraignmentContinuance.docx";
            await JS.InvokeVoidAsync("downloadFile", fileName, "application/vnd.openxmlformats-officedocument.wordprocessingml.document", content);
        }
    }

    private void CloseOrCancel() => Navigation.NavigateTo("/");
    private void ClearFields() { continuance = new(); }
}
