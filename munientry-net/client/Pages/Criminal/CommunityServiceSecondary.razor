@page "/criminal/community-service-secondary"
@inherits FormPageBase<CommunityServiceSecondaryDto>

<div class="form-page">
<div class="form-card">
<h2>Community Service, License Suspension, Fingerprinting &amp; Victim Notification, Immobilize/Impound and other Conditions Secondary Dialogs</h2>

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
	<FluentValidationValidator />
	<ValidationSummary />
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.CommunityServiceOrdered" />
		<label>Community Service Ordered</label>
	</div>
	<div class="form-group">
		<label>Community Service Hours</label>
		<InputText class="form-control" @bind-Value="Model.CommunityServiceHours" />
	</div>
	<div class="form-group">
		<label>Community Service Days to Complete</label>
		<InputText class="form-control" @bind-Value="Model.CommunityServiceDaysToComplete" />
	</div>
	<div class="form-group">
		<label>Community Service Due Date</label>
		<InputDate class="form-control" @bind-Value="Model.CommunityServiceDueDate" />
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.LicenseSuspensionOrdered" />
		<label>License Suspension Ordered</label>
	</div>
	<div class="form-group">
		<label>License Suspension Length</label>
		<InputText class="form-control" @bind-Value="Model.LicenseSuspensionLength" />
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.FingerprintingOrdered" />
		<label>Fingerprinting Ordered</label>
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.VictimNotificationOrdered" />
		<label>Victim Notification Ordered</label>
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.ImmobilizeImpoundOrdered" />
		<label>Immobilize/Impound Ordered</label>
	</div>
	<div class="form-group">
		<label>Other Conditions</label>
		<InputText class="form-control" @bind-Value="Model.OtherConditions" />
	</div>
	<div class="form-actions">
		<button type="submit" class="btn btn-success">Open Entry</button>
		<button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
		<button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
		<button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
	</div>
</EditForm>

@if (ErrorMessage != null)
{
	<div class="alert alert-danger">@ErrorMessage</div>
}
@if (SubmitResult != null)
{
	<div class="alert alert-success">@SubmitResult</div>
}
</div>
</div>
@code {
	protected override string ApiEndpoint => "communityservicesecondary";
}
