@page "/criminal/fine-only-plea-only"
@page "/criminal/fine-only-plea-only/{CaseNumber}"
@inherits FormPageBase<FineOnlyDto>

<div class="form-page">
<div class="form-card">
<h2>Fine Only Dialog</h2>
<!-- Legacy: fine_only_plea_dialog_ui.py, plea_only_dialog_ui.py -->

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
	<FluentValidationValidator />
	<ValidationSummary />
	<div class="form-group">
		<label>Case Number</label>
		<InputText @bind-Value="Model.CaseNumber" class="form-control" />
	</div>
	<div class="form-group">
		<label>Defendant Name</label>
		<InputText @bind-Value="Model.DefendantName" class="form-control" />
	</div>
	<div class="form-group">
		<label>Charge</label>
		<InputText @bind-Value="Model.Charge" class="form-control" />
	</div>
	<div class="form-group">
		<label>Fine Amount</label>
		<InputNumber @bind-Value="Model.FineAmount" TValue="decimal?" class="form-control" />
	</div>
	<div class="form-actions">
		<button type="submit" class="btn btn-success" disabled="@(IsSubmitting || IsLoadingCase)">Open Entry</button>
		<button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
		<button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
		<button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
		<span style="margin-left:1rem">@(ErrorMessage ?? SubmitResult)</span>
	</div>
</EditForm>

</div>
</div>

@code {

	protected override string ApiEndpoint => "fineonly";

	protected override Task PopulateFromCaseAsync(List<CaseSearchResultDto> results)
	{
		var first = results[0];
		Model.CaseNumber = CaseNumber;
		Model.DefendantName = $"{first.DefFirstName} {first.DefLastName}".Trim();
		Model.Charge = string.Join("; ", results
			.Where(r => r.Charge != null)
			.Select(r => $"{r.Charge} ({r.Statute}) - {r.DegreeCode}"));
		return Task.CompletedTask;
	}
}
