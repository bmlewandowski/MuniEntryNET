@page "/criminal/leap-admission-plea"
@page "/criminal/leap-admission-plea/{CaseNumber}"
@inherits FormPageBase<LeapAdmissionPleaDto>

<div class="form-page">
<div class="form-card">
<h2>LEAP Plea Admission Dialog</h2>

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
<FluentValidationValidator />
@if (IsLoadingCase)
{
<div class="alert alert-info">Loading case data...</div>
}
	<ValidationSummary />
	<div class="form-group">
		<label>Defendant First Name</label>
		<InputText class="form-control" @bind-Value="Model.DefendantFirstName" />
		<ValidationMessage For="@(() => Model.DefendantFirstName)" />
	</div>
	<div class="form-group">
		<label>Defendant Last Name</label>
		<InputText class="form-control" @bind-Value="Model.DefendantLastName" />
		<ValidationMessage For="@(() => Model.DefendantLastName)" />
	</div>
	<div class="form-group">
		<label>Case Number</label>
		<InputText class="form-control" @bind-Value="Model.CaseNumber" />
		<ValidationMessage For="@(() => Model.CaseNumber)" />
	</div>
	<div class="form-group">
		<label>Defense Counsel Name</label>
		<InputText class="form-control" @bind-Value="Model.DefenseCounselName" />
	</div>
	<div class="form-group">
		<label>Defense Counsel Type</label>
		<InputText class="form-control" @bind-Value="Model.DefenseCounselType" />
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.DefenseCounselWaived" />
		<label>Defendant waived right to counsel</label>
	</div>
	<div class="form-group">
		<label>Appearance Reason</label>
		<InputText class="form-control" @bind-Value="Model.AppearanceReason" />
	</div>
	<div class="form-group">
		<label>Plea Date</label>
		<InputDate class="form-control" @bind-Value="Model.PleaDate" />
	</div>
	<div class="form-group">
		<label>Offense</label>
		<InputText class="form-control" @bind-Value="Model.Charges" />
	</div>
	<div class="form-group">
		<label>Statute/Ord.</label>
		<InputText class="form-control" @bind-Value="Model.ChargeStatute" />
	</div>
	<div class="form-group">
		<label>Degree</label>
		<InputSelect class="form-select" @bind-Value="Model.ChargeDegree">
			<option value="">Select Degree</option>
			<option value="Misdemeanor">Misdemeanor</option>
			<option value="Felony">Felony</option>
			<option value="Infraction">Infraction</option>
			<option value="Other">Other</option>
		</InputSelect>
	</div>
	<div class="form-group">
		<label>Plea</label>
		<InputSelect class="form-select" @bind-Value="Model.ChargePlea">
			<option value="">Select Plea</option>
			<option value="Guilty">Guilty</option>
			<option value="No Contest">No Contest</option>
			<option value="Not Guilty">Not Guilty</option>
			<option value="Other">Other</option>
		</InputSelect>
	</div>
	<div class="form-group">
		<label>Court Costs</label>
		<InputText class="form-control" @bind-Value="Model.CourtCosts" />
	</div>
	<div class="form-group">
		<label>Ability to Pay</label>
		<InputText class="form-control" @bind-Value="Model.AbilityToPay" />
	</div>
	<div class="form-group">
		<label>Balance Due Date</label>
		<InputDate class="form-control" @bind-Value="Model.BalanceDueDate" />
	</div>
	<div class="form-group">
		<label>Pay Today</label>
		<InputText class="form-control" @bind-Value="Model.PayToday" />
	</div>
	<div class="form-group">
		<label>Monthly Pay</label>
		<InputText class="form-control" @bind-Value="Model.MonthlyPay" />
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.CreditForJail" />
		<label>Credit for Jail</label>
	</div>
	<div class="form-group">
		<label>Jail Time Credit Days</label>
		<InputText class="form-control" @bind-Value="Model.JailTimeCreditDays" />
	</div>
	<div class="form-group">
		<label>FRA in File</label>
		<InputText class="form-control" @bind-Value="Model.FraInFile" />
	</div>
	<div class="form-group">
		<label>FRA in Court</label>
		<InputText class="form-control" @bind-Value="Model.FraInCourt" />
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.LicenseSuspension" />
		<label>License Suspension</label>
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.CommunityService" />
		<label>Community Service</label>
	</div>
	<div class="form-group">
		<InputCheckbox @bind-Value="Model.OtherConditions" />
		<label>Other Conditions</label>
	</div>
	<div class="form-actions">
		<button type="submit" class="btn btn-success" disabled="@(IsSubmitting || IsLoadingCase)">Open Entry</button>
		<button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
		<button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
		<button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
	</div>
</EditForm>

@if (SubmitResult != null)
{
	<div class="alert alert-info">@SubmitResult</div>
}
</div>
</div>
@code {

	protected override string ApiEndpoint => "leapadmissionplea";

	protected override Task PopulateFromCaseAsync(List<CaseSearchResultDto> results)
	{
		var first = results[0];
		Model.CaseNumber = CaseNumber;
		Model.DefendantFirstName = first.DefFirstName;
		Model.DefendantLastName = first.DefLastName;
		Model.DefenseCounselName = first.DefenseCounsel;
		Model.DefenseCounselType = first.PubDef ? "Public Defender" : "Private Counsel";
		Model.FraInFile = first.FraInFile;
		var firstCharge = results.FirstOrDefault(r => r.Charge != null);
		if (firstCharge != null)
		{
			Model.Charges = firstCharge.Charge ?? "";
			Model.ChargeStatute = firstCharge.Statute ?? "";
			Model.ChargeDegree = firstCharge.DegreeCode ?? "";
			Model.ChargePlea = "";
		}
		return Task.CompletedTask;
	}
}
