@page "/criminal/deny-privileges-permit-retest"
@page "/criminal/deny-privileges-permit-retest/{CaseNumber}"
@inherits FormPageBase<DenyPrivilegesPermitRetestDto>

<div class="form-page">
<div class="form-card">
<h2>Deny Privileges / Permit Retest</h2>
<!-- Legacy: deny_privileges_permit_retest_dialog_ui.py -->

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
    <FluentValidationValidator />
    @if (IsLoadingCase)
    {
        <div class="alert alert-info">Loading case data...</div>
    }
    <ValidationSummary />
    <div class="form-group">
        <label>Defendant First Name</label>
        <InputText @bind-Value="Model.DefendantFirstName" class="form-control" />
    </div>
    <div class="form-group">
        <label>Defendant Last Name</label>
        <InputText @bind-Value="Model.DefendantLastName" class="form-control" />
    </div>
    <div class="form-group">
        <label>Case Number</label>
        <InputText @bind-Value="Model.CaseNumber" class="form-control" />
    </div>
    <div class="form-group">
        <label>Entry Date</label>
        <InputDate @bind-Value="Model.EntryDate" class="form-control" />
    </div>
    <div class="form-group">
        <label>Driving Privileges Entry Type</label>
        <InputRadioGroup @bind-Value="Model.EntryType">
            <div class="form-check">
                <InputRadio Value="EntryType.DenyDrivingPrivileges" class="form-check-input" />
                <label class="form-check-label">Deny Driving Privileges</label>
            </div>
            <div class="form-check">
                <InputRadio Value="EntryType.PermitTest" class="form-check-input" />
                <label class="form-check-label">Permit Defendant to Test and/or Renew</label>
            </div>
            <div class="form-check">
                <InputRadio Value="EntryType.PermitRenew" class="form-check-input" />
                <label class="form-check-label">Permit Defendant to Renew upon Expiration</label>
            </div>
            <div class="form-check">
                <InputRadio Value="EntryType.TerminatePrivileges" class="form-check-input" />
                <label class="form-check-label">Terminate Privileges - Fail to Pay</label>
            </div>
        </InputRadioGroup>
    </div>
    <div class="form-group">
        <label>Eligibility/Status</label>
        <div class="form-check">
            <InputCheckbox @bind-Value="Model.HardTimeNotPassed" class="form-check-input" />
            <label class="form-check-label">Not Eligible - Hard Time has not passed</label>
        </div>
        <div class="form-check">
            <InputCheckbox @bind-Value="Model.PermanentIdCard" class="form-check-input" />
            <label class="form-check-label">Defendant has permanent ID card</label>
        </div>
        <div class="form-check">
            <InputCheckbox @bind-Value="Model.OutOfStateLicense" class="form-check-input" />
            <label class="form-check-label">Out of State License - Needs Certified Abstract</label>
        </div>
        <div class="form-check">
            <InputCheckbox @bind-Value="Model.PetitionIncomplete" class="form-check-input" />
            <label class="form-check-label">Petition is Incomplete and/or Illegible</label>
        </div>
        <div class="form-check">
            <InputCheckbox @bind-Value="Model.NoInsurance" class="form-check-input" />
            <label class="form-check-label">Failed to Provide Proof of Insurance</label>
        </div>
        <div class="form-check">
            <InputCheckbox @bind-Value="Model.NoEmployerInfo" class="form-check-input" />
            <label class="form-check-label">Court could not verify employer information</label>
        </div>
        <div class="form-check">
            <InputCheckbox @bind-Value="Model.NoJurisdiction" class="form-check-input" />
            <label class="form-check-label">License not subject to suspension for which this court may grant privileges</label>
        </div>
        <div class="form-check">
            <InputCheckbox @bind-Value="Model.NoPayPlan" class="form-check-input" />
            <label class="form-check-label">Defendant not on or current with fines and costs pay plan</label>
        </div>
        <div class="form-check">
            <InputCheckbox @bind-Value="Model.ProhibitedActivities" class="form-check-input" />
            <label class="form-check-label">Petition requests privileges for activities not permitted by this Court</label>
        </div>
    </div>
    <div class="form-group">
        <label>Defendant Driver License Expiration Date</label>
        <InputDate @bind-Value="Model.LicenseExpirationDate" class="form-control" />
    </div>
    <div class="form-group">
        <label>Date Privileges were Granted on</label>
        <InputDate @bind-Value="Model.PrivilegesGrantDate" class="form-control" />
    </div>
    <div class="form-group">
        <label>Notice of Unpaid Fines and Costs (NUFC) Letter Date</label>
        <InputDate @bind-Value="Model.NufcDate" class="form-control" />
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-success" disabled="@(IsSubmitting || IsLoadingCase)">Generate DOCX</button>
        <button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
        <button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
        <button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
    </div>
    @if (ErrorMessage != null)
    {
        <div class="alert alert-danger mt-2">@ErrorMessage</div>
    }
    @if (SubmitResult != null)
    {
        <div class="alert alert-success mt-2">@SubmitResult</div>
    }
</EditForm>
</div>
</div>

@code {

    protected override void OnInitialized()
    {
        Model.EntryType = EntryType.DenyDrivingPrivileges;
    }

    protected override string ApiEndpoint => "denyprivilegespermitretest";

    protected override Task PopulateFromCaseAsync(List<CaseSearchResultDto> results)
    {
        var first = results[0];
        Model.CaseNumber = CaseNumber;
        Model.DefendantFirstName = first.DefFirstName;
        Model.DefendantLastName = first.DefLastName;
        return Task.CompletedTask;
    }

    protected override void ClearFields()
    {
        base.ClearFields();
        Model.EntryType = EntryType.DenyDrivingPrivileges;
    }
}
