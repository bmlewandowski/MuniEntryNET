@page "/criminal/leap-admission-already-valid"
@page "/criminal/leap-admission-already-valid/{CaseNumber}"
@inherits FormPageBase<LeapAdmissionAlreadyValidDto>

<div class="form-page">
    <div class="form-card">
        <h2>LEAP Admission - Already Valid Dialog</h2>
        <!-- Legacy: leap_plea_valid_dialog_ui.py -->
        <EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
            <FluentValidationValidator />
    @if (IsLoadingCase)
    {
        <div class="alert alert-info">Loading case data...</div>
    }
    @if (IsLoadingCase)
    {
        <div class="alert alert-info">Loading case data...</div>
    }
    @if (IsLoadingCase)
    {
        <div class="alert alert-info">Loading case data...</div>
    }
    @if (IsLoadingCase)
    {
        <div class="alert alert-info">Loading case data...</div>
    }
            <ValidationSummary />
            <div class="form-group">
                <label>Defendant First Name</label>
                <InputText class="form-control" @bind-Value="Model.DefendantFirstName" />
                <ValidationMessage For="@(() => Model.DefendantFirstName)" />
            </div>
            <div class="form-group">
                <label>Defendant Last Name</label>
                <InputText class="form-control" @bind-Value="Model.DefendantLastName" />
                <ValidationMessage For="@(() => Model.DefendantLastName)" />
            </div>
            <div class="form-group">
                <label>Case Number</label>
                <InputText class="form-control" @bind-Value="Model.CaseNumber" />
                <ValidationMessage For="@(() => Model.CaseNumber)" />
            </div>
            <div class="form-group">
                <label>Defense Counsel Name</label>
                <InputText class="form-control" @bind-Value="Model.DefenseCounselName" />
            </div>
            <div class="form-group">
                <CheckboxInline Value="Model.DefenseCounselWaived" ValueChanged="@(v => Model.DefenseCounselWaived = v)" ValueExpression="@(() => Model.DefenseCounselWaived)" Label="Defendant waived right to counsel" />
            </div>
            <div class="form-group">
                <label>Appearance Reason</label>
                <InputText class="form-control" @bind-Value="Model.AppearanceReason" />
            </div>
            <div class="form-group">
                <label>Admission Date</label>
                <InputDate class="form-control" @bind-Value="Model.AdmissionDate" />
            </div>
            <div class="form-group" style="max-width:100%;">
                <label>Charges</label>
                <table class="table table-bordered table-sm">
                    <thead>
                        <tr>
                            <th>Offense</th>
                            <th>Statute</th>
                            <th>Degree</th>
                            <th>Plea</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var charge in Charges)
                        {
                            <tr>
                                <td>
                                    <InputText class="form-control form-control-sm" @bind-Value="charge.Offense" />
                                </td>
                                <td>
                                    <InputText class="form-control form-control-sm" @bind-Value="charge.Statute" />
                                </td>
                                <td>
                                    <InputSelect class="form-select form-select-sm" @bind-Value="charge.Degree">
                                        <option value="">Select Degree</option>
                                        <option value="Misdemeanor">Misdemeanor</option>
                                        <option value="Felony">Felony</option>
                                        <option value="Infraction">Infraction</option>
                                        <option value="Other">Other</option>
                                    </InputSelect>
                                </td>
                                <td>
                                    <InputSelect class="form-select form-select-sm" @bind-Value="charge.Plea">
                                        <option value="">Select Plea</option>
                                        <option value="Guilty">Guilty</option>
                                        <option value="No Contest">No Contest</option>
                                        <option value="Not Guilty">Not Guilty</option>
                                        <option value="Other">Other</option>
                                    </InputSelect>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-danger btn-sm me-1" @onclick="() => DeleteCharge(charge)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <button type="button" class="btn btn-info btn-sm me-2" @onclick="AddCharge">Add Charge</button>
                <button type="button" class="btn btn-secondary btn-sm me-2" @onclick="GuiltyAll">Guilty All</button>
            </div>
            <div class="form-group">
                <label>Court Costs</label>
                <InputText class="form-control" @bind-Value="Model.CourtCosts" />
            </div>
            <div class="form-group">
                <label>Ability to Pay</label>
                <InputText class="form-control" @bind-Value="Model.AbilityToPay" />
            </div>
            <div class="form-group">
                <label>Balance Due Date</label>
                <InputDate class="form-control" @bind-Value="Model.BalanceDueDate" />
            </div>
            <div class="form-group">
                <CheckboxInline @bind-Value="Model.CreditForJail" Label="Credit for Jail" />
            </div>
            <div class="form-group">
                <label>Monthly Pay</label>
                <InputText class="form-control" @bind-Value="Model.MonthlyPay" />
            </div>
            <div class="form-group">
                <label>Jail Time Credit Days</label>
                <InputText class="form-control" @bind-Value="Model.JailTimeCreditDays" />
            </div>
            <div class="form-group">
                <CheckboxInline @bind-Value="Model.LicenseSuspension" Label="License Suspension" />
            </div>
            <div class="form-group">
                <CheckboxInline @bind-Value="Model.CommunityService" Label="Community Service" />
            </div>
            <div class="form-group">
                <CheckboxInline @bind-Value="Model.OtherConditions" Label="Other Conditions" />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-success me-2" disabled="@(IsSubmitting || IsLoadingCase)">Generate DOCX</button>
                <button type="button" class="btn btn-danger me-2" @onclick="CloseOrCancel">Close Dialog</button>
                <button type="button" class="btn btn-secondary me-2" @onclick="CloseOrCancel">Cancel</button>
                <button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
            </div>
            @if (ErrorMessage != null)
            {
                <div class="alert alert-danger mt-2">@ErrorMessage</div>
            }
            @if (SubmitResult != null)
            {
                <div class="alert alert-success mt-2">@SubmitResult</div>
            }
        </EditForm>
    </div>
</div>

@code {

    // Charge grid (separate from the main DTO charge summary field)
    private List<ChargeDto> Charges { get; set; } = new();

    protected override string ApiEndpoint => "leapadmissionalreadyvalid";

    protected override async Task HandleValidSubmit()
    {
        Model.ChargeItems = Charges
            .Select(c => new ChargeItemDto
            {
                Offense = c.Offense,
                Statute = c.Statute,
                Degree  = c.Degree,
                Plea    = c.Plea,
            })
            .ToList();
        await base.HandleValidSubmit();
    }

    protected override Task PopulateFromCaseAsync(List<CaseSearchResultDto> results)
    {
        var first = results[0];
        Model.CaseNumber = CaseNumber;
        Model.DefendantFirstName = first.DefFirstName;
        Model.DefendantLastName = first.DefLastName;
        Model.DefenseCounselName = first.DefenseCounsel;
        Model.DefenseCounselType = first.PubDef ? "Public Defender" : "Private Counsel";
        Model.FraInFile = first.FraInFile;
        Charges = results
            .Where(r => r.Charge != null)
            .Select(r => new ChargeDto { Offense = r.Charge!, Statute = r.Statute ?? "", Degree = r.DegreeCode ?? "" })
            .ToList();
        return Task.CompletedTask;
    }

    private void AddCharge() => Charges.Add(new ChargeDto());
    private void AmendCharge(ChargeDto charge) { /* inline edit */ }
    private void DeleteCharge(ChargeDto charge) => Charges.Remove(charge);
    private void GuiltyAll() { foreach (var c in Charges) c.Plea = "Guilty"; }

    protected override void ClearFields() { base.ClearFields(); Charges = new(); }

    public class ChargeDto
    {
        public string Offense { get; set; } = string.Empty;
        public string Statute { get; set; } = string.Empty;
        public string Degree { get; set; } = string.Empty;
        public string Plea { get; set; } = string.Empty;
    }
}
