@page "/case/docket"
@page "/case/docket/{CaseNumber}"
@using Munientry.Client.Shared
@inject ReportsApiClient ReportsSvc
@inject NavigationManager Navigation

<PageTitle>Case Docket</PageTitle>

<div class="form-page">
    <div class="form-card">
        <h2>Case Docket</h2>
        <p class="form-subtitle">
            Enter a case number to view the chronological docket entries from AuthorityCourt.
            Equivalent to the legacy <em>CrimCaseDocket.get_docket()</em> lookup.
        </p>

        <div class="daily-list-toolbar">
            <div class="form-group">
                <label>Case Number</label>
                <input type="text"
                       class="form-control"
                       placeholder="e.g. 22CRB01234"
                       @bind="InputCaseNumber"
                       @onkeydown="OnKeyDown" />
            </div>
            <button class="btn btn-primary" @onclick="LoadDocketAsync" disabled="@IsLoading">
                @(IsLoading ? "Loading…" : "Load Docket")
            </button>
        </div>

        @if (ErrorMessage is not null)
        {
            <div class="alert alert-danger mt-2">@ErrorMessage</div>
        }

        @if (_entries is not null)
        {
            <div class="mt-3">
                <h4>@(_queriedCaseNumber) — @_entries.Count docket @(_entries.Count == 1 ? "entry" : "entries")</h4>

                @if (_entries.Count == 0)
                {
                    <p class="text-muted">No docket entries found for this case.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover report-table">
                            <thead>
                                <tr>
                                    <th style="width:130px">Date</th>
                                    <th>Docket Entry</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in _entries)
                                {
                                    <tr>
                                        <td class="text-nowrap">
                                            @(entry.Date.HasValue ? entry.Date.Value.ToString("MM/dd/yyyy") : "—")
                                        </td>
                                        <td>@(entry.Remark ?? "")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="form-actions mt-2">
                        <button class="btn btn-secondary btn-sm" @onclick="PrintTable">⊞ Print</button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {

    // ── Parameters ─────────────────────────────────────────────────────────────
    [Parameter] public string? CaseNumber { get; set; }

    // ── State ──────────────────────────────────────────────────────────────────
    private string InputCaseNumber  { get; set; } = string.Empty;
    private bool   IsLoading        { get; set; }
    private string? ErrorMessage    { get; set; }
    private string? _queriedCaseNumber;
    private List<CaseDocketEntryDto>? _entries;

    [Inject] IJSRuntime JS { get; set; } = default!;

    // ── Lifecycle ───────────────────────────────────────────────────────────────
    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(CaseNumber) && CaseNumber != _queriedCaseNumber)
        {
            InputCaseNumber = CaseNumber;
            await LoadDocketAsync();
        }
    }

    // ── Event handlers ──────────────────────────────────────────────────────────
    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadDocketAsync();
    }

    private async Task LoadDocketAsync()
    {
        if (string.IsNullOrWhiteSpace(InputCaseNumber))
        {
            ErrorMessage = "Please enter a case number.";
            return;
        }

        IsLoading = true;
        ErrorMessage = null;
        _entries = null;

        try
        {
            _queriedCaseNumber = InputCaseNumber.Trim().ToUpper();
            _entries = await ReportsSvc.GetCaseDocketAsync(_queriedCaseNumber);

            if (_entries.Count == 0)
                ErrorMessage = $"No docket entries found for case '{_queriedCaseNumber}'. " +
                               "Verify the case number is correct and exists in AuthorityCourt.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading docket: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task PrintTable() =>
        await JS.InvokeVoidAsync("window.print");
}
