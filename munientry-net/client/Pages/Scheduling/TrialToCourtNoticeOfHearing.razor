@page "/scheduling/trial-to-court-notice-of-hearing"
@inherits FormPageBase<TrialToCourtNoticeDto>

<div class="form-page">
<div class="form-card">
<h2>Hemmeter/Rohrer Trial to Court Notice of Hearing Dialog</h2>
<!-- Legacy: trial_to_court_notice_of_hearing_dialog_ui.py -->

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
    <FluentValidationValidator />
    <ValidationSummary />
    <div class="form-group">
        <label>Defendant First Name</label>
        <InputText @bind-Value="Model.DefendantFirstName" class="form-control" />
        <ValidationMessage For="@(() => Model.DefendantFirstName)" />
    </div>
    <div class="form-group">
        <label>Defendant Last Name</label>
        <InputText @bind-Value="Model.DefendantLastName" class="form-control" />
        <ValidationMessage For="@(() => Model.DefendantLastName)" />
    </div>
    <div class="form-group">
        <label>Case Number</label>
        <InputText @bind-Value="Model.CaseNumber" class="form-control" />
        <ValidationMessage For="@(() => Model.CaseNumber)" />
    </div>
    <div class="form-group">
        <label>Entry Date</label>
        <InputDate @bind-Value="Model.EntryDate" class="form-control" />
        <ValidationMessage For="@(() => Model.EntryDate)" />
    </div>
    <div class="form-group">
        <label>Defense Counsel Name</label>
        <InputText @bind-Value="Model.DefenseCounselName" class="form-control" />
    </div>
    <div class="form-group">
        <label>Trial To Court Date</label>
        <InputDate @bind-Value="Model.TrialToCourtDate" class="form-control" />
        <ValidationMessage For="@(() => Model.TrialToCourtDate)" />
    </div>
    <div class="form-group">
        <label>Trial To Court Time</label>
        <InputSelect @bind-Value="Model.TrialToCourtTime" class="form-control">
            <option value="">Select...</option>
            <option>9:30 AM</option>
            <option>10:00 AM</option>
            <option>10:30 AM</option>
            <option>11:00 AM</option>
            <option>11:30 AM</option>
            <option>1:00 PM</option>
            <option>1:30 PM</option>
            <option>2:00 PM</option>
            <option>2:30 PM</option>
            <option>3:00 PM</option>
        </InputSelect>
        <ValidationMessage For="@(() => Model.TrialToCourtTime)" />
    </div>
    <div class="form-group">
        <label>Assigned Courtroom</label>
        <InputSelect @bind-Value="Model.AssignedCourtroom" class="form-control">
            <option value="">Select...</option>
            <option>Courtroom C</option>
            <option>Courtroom B</option>
            <option>Courtroom A</option>
        </InputSelect>
        <ValidationMessage For="@(() => Model.AssignedCourtroom)" />
    </div>
    <div class="form-group">
        <label>Interpreter Required</label>
        <InputCheckbox @bind-Value="Model.InterpreterRequired" />
    </div>
    <div class="form-group">
        <label>Language Required</label>
        <InputText @bind-Value="Model.LanguageRequired" class="form-control" />
    </div>
    <div class="form-group">
        <label>Date Confirmed with Counsel</label>
        <InputCheckbox @bind-Value="Model.DateConfirmedWithCounsel" />
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-success" disabled="@IsSubmitting">Generate DOCX</button>
        <button type="button" class="btn btn-danger" @onclick="CloseOrCancel">Close Dialog</button>
        <button type="button" class="btn btn-secondary" @onclick="CloseOrCancel">Cancel</button>
        <button type="button" class="btn btn-warning" @onclick="ClearFields">Clear Fields</button>
    </div>
    @if (ErrorMessage != null)
    {
        <div class="alert alert-danger mt-2">@ErrorMessage</div>
    }
</EditForm>
</div>
</div>

			@code {
				protected override string ApiEndpoint => "trialtocourt";
			}
