{
  "ApiBaseUrl": "http://localhost:5000/api/v1/",

  // -----------------------------------------------------------------------
  // MOCK USER — Development / testing without Entra ID
  //
  // Set this to any key defined under Staff:JudicialOfficers below.
  // The MockJudicialOfficerProvider reads this value at startup to resolve
  // the judicial officer without requiring authentication.
  //
  // Use "visiting_judge" to test the visiting-judge name-entry modal.
  // Set to "" (empty string) to test the "unknown user" fallback.
  //
  // When Entra ID is enabled, this setting is ignored entirely.
  // -----------------------------------------------------------------------
  "MockUser": "judge_1",

  // -----------------------------------------------------------------------
  // STAFF — mirrors the [staff] section of the legacy Python config.ini.
  // Keys must match the MockUser value (or the upn suffix used by the
  // EntraIdJudicialOfficerProvider when Entra ID is enabled).
  // -----------------------------------------------------------------------
  "Staff": {
    "JudicialOfficers": {
      "judge_1": {
        "FirstName": "Mark",
        "LastName": "Fowler",
        "OfficerType": "Judge"
      },
      "judge_2": {
        "FirstName": "Kyle",
        "LastName": "Rohrer",
        "OfficerType": "Judge"
      },
      "magistrate_1": {
        "FirstName": "Amanda",
        "LastName": "Bunner",
        "OfficerType": "Magistrate"
      },
      "magistrate_2": {
        "FirstName": "Kevin",
        "LastName": "Pelanda",
        "OfficerType": "Magistrate"
      },
      "magistrate_3": {
        "FirstName": "Justin",
        "LastName": "Kudela",
        "OfficerType": "Magistrate"
      },
      "visiting_judge": {
        "FirstName": "Visiting",
        "LastName": "Judge",
        "OfficerType": "Visiting Judge",
        "IsVisiting": true
      }
    }
  },

  // ENTRA ID - Fill in TenantId and ClientId after registering the app in Entra ID (Azure Portal).
  // The ClientId comes from the App Registration created for this Blazor WASM client.
  // RedirectUri must match the redirect URI configured on the App Registration (default: https://localhost/).
  "AzureAd": {
    "Authority": "https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID",
    "ClientId": "REPLACE_WITH_CLIENT_ID",
    "ValidateAuthority": true
  }
}
