@inherits LayoutComponentBase
@inject JudicialOfficerSession OfficerSession

@code {
    private bool sidebarCollapsed = false;
    private string SidebarClass => sidebarCollapsed ? "sidebar collapsed" : "sidebar";
}

<AppInitializer>
<div class="layout-root">
    <aside class="@SidebarClass">
        <button class="sidebar-toggle" @onclick="() => sidebarCollapsed = !sidebarCollapsed" aria-label="Toggle navigation">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>
        <nav>
            <details open>
                <summary><b>Criminal / Plea & Sentencing</b></summary>
                <ul>
                    <li><a href="/criminal/arraignmentcontinuance">Arraignment Continuance</a></li>
                    <li><a href="/criminal/fineonlyplea">Plea of Guilty - Fine Only</a></li>
                    <li><a href="/criminal/fine-only-plea-only">Fine Only Plea Only</a></li>
                    <li><a href="/criminal/diversion-plea">Diversion Plea</a></li>
                    <li><a href="/criminal/diversion-dialog">Diversion Dialog (Secondary)</a></li>
                    <li><a href="/criminal/plea-only-future-sentencing">Plea Only / Future Sentencing</a></li>
                    <li><a href="/criminal/leap-admission-plea">LEAP Admission / Plea</a></li>
                    <li><a href="/criminal/leap-admission-already-valid">LEAP Admission - Already Valid</a></li>
                    <li><a href="/criminal/leap-valid-sentencing">LEAP Sentencing - Already Valid</a></li>
                    <li><a href="/criminal/leap-sentencing">LEAP Sentencing</a></li>
                    <li><a href="/criminal/jail-cc-plea">Plea of Guilty - Jail/CC Only</a></li>
                    <li><a href="/criminal/trial-sentencing">Trial Sentencing / Final Jury</a></li>
                    <li><a href="/criminal/sentencing-only-already-plead">Sentencing Only (Already Plead)</a></li>
                    <li><a href="/criminal/not-guilty-plea">Plea of Not Guilty</a></li>
                    <li><a href="/criminal/not-guilty-appear-bond-special">Plea of Not Guilty / Appear on Warrant / Bond Modification (Special Bond Conditions)</a></li>
                    <li><a href="/criminal/appear-on-warrant-no-plea">Appear on Warrant (No Plea)</a></li>
                    <li><a href="/criminal/bond-modification-revocation">Bond Modification / Revocation</a></li>
                    <li><a href="/criminal/community-service-secondary">Community Service / License Suspension / Fingerprinting / Victim Notification / Immobilize-Impound / Other Conditions (Secondary)</a></li>
                    <li><a href="/criminal/arraignment-fta-bond">Arraignment / Failure to Appear / Bond</a></li>
                    <li><a href="/criminal/deny-privileges-permit-retest">Deny Privileges / Permit Retest</a></li>
                    <li><a href="/criminal/failure-to-appear">Failure To Appear</a></li>
                    <li><a href="/criminal/criminal-sealing">Criminal Sealing Entry</a></li>
                    <li><a href="/criminal/competency-evaluation">Competency Evaluation</a></li>
                    <li><a href="/criminal/freeform-entry">Criminal Freeform Entry</a></li>
                </ul>
            </details>
            <details>
                <summary><b>Scheduling / Court Events</b></summary>
                <ul>
                    <li><a href="/scheduling/trial-to-court-notice-of-hearing">Trial to Court Notice of Hearing</a></li>
                    <li><a href="/scheduling/general-notice-of-hearing">General Notice of Hearing</a></li>
                    <li><a href="/scheduling/scheduling-entry">Scheduling Entry</a></li>
                </ul>
            </details>
            <details>
                <summary><b>Probation / Community Control</b></summary>
                <ul>
                    <li><a href="/probation/violation-bond">Preliminary Probation Violation & Bond</a></li>
                    <li><a href="/probation/community-control-terms">Community Control Terms</a></li>
                    <li><a href="/probation/community-control-terms-notices">Terms of Community Control / Notice of Violation Hearing</a></li>
                </ul>
            </details>
            <details>
                <summary><b>Admin / Courtroom Operations</b></summary>
                <ul>
                    <li><a href="/admin/workflows-fiscal">Fiscal Journal Entry</a></li>
                    <li><a href="/admin/juror-payment">Juror Payment</a></li>
                    <li><a href="/admin/time-to-pay-order">Time to Pay Order</a></li>
                </ul>
            </details>
            <details>
                <summary><b>Notices / Freeform / Civil</b></summary>
                <ul>
                    <li><a href="/notices/notices-freeform-civil">Civil Freeform Notice</a></li>
                    <li><a href="/notices/civil-freeform-entry">Civil Freeform Entry</a></li>
                </ul>
            </details>
            <details>
                <summary><b>Driving / Traffic</b></summary>
                <ul>
                    <li><a href="/driving/driving-privileges">Limited Driving Privileges</a></li>
                </ul>
            </details>
            <details>
                <summary><b>Reports</b></summary>
                <ul>
                    <li><a href="/reports/not-guilty">Not Guilty Report</a></li>
                    <li><a href="/reports/event">Event Report</a></li>
                    <li><a href="/reports/fta">Batch FTA Entries</a></li>
                    <li><a href="/case/docket">Case Docket Lookup</a></li>
                </ul>
            </details>

        </nav>
    </aside>
    <main class="main-content">
        <div class="officer-banner">
            @if (OfficerSession.IsInitialized && OfficerSession.JudicialOfficer is not null)
            {
                <span class="officer-label">
                    @OfficerSession.JudicialOfficer.OfficerType: <strong>@OfficerSession.JudicialOfficer.FullName</strong>
                </span>
            }
            else
            {
                <span class="officer-label officer-unknown">No judicial officer selected</span>
            }
        </div>
        @Body
    </main>
</div>
</AppInitializer>
